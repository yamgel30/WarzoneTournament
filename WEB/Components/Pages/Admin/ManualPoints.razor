@page "/admin/manual-points"
@using WarzoneTournament.Application.Common.Interfaces
@using WarzoneTournament.Application.DTOs.Match
@using WarzoneTournament.Application.DTOs.Tournament
@using WarzoneTournament.Domain.Enums
@inject ITournamentService TournamentService
@inject ITeamService TeamService
@inject IMatchService MatchService
@inject ILeaderboardService LeaderboardService
@inject NavigationManager NavManager

<PageTitle>Resultados de Mapas - Admin</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Ingresar Resultados</h1>
        <RadzenButton Text="Volver al Admin" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => NavManager.NavigateTo("/admin"))" />
    </div>

    @* ── Paso 1: Torneo ── *@
    <RadzenCard class="mb-3">
        <h3 class="rz-mb-3">1. Selecciona el torneo</h3>
        @if (_loadingTournaments)
        {
            <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
        }
        else
        {
            <RadzenDropDown @bind-Value="_selectedTournamentId"
                            Data="@_tournaments"
                            TextProperty="Name"
                            ValueProperty="Id"
                            Placeholder="-- Elige un torneo --"
                            Style="width:100%;max-width:500px"
                            Change="@OnTournamentSelected" />
        }
    </RadzenCard>

    @* ── Paso 2: Match ── *@
    @if (_selectedTournamentId != Guid.Empty)
    {
        <RadzenCard class="mb-3">
            <h3 class="rz-mb-3">2. Selecciona el mapa (match)</h3>
            @if (_loadingMatches)
            {
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
            }
            else if (!_matches.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
                    No hay matches en este torneo. Créalos primero en
                    <RadzenLink Text="Setup del Torneo" Path="@($"/admin/setup/{_selectedTournamentId}")" /> → pestaña Rondas.
                </RadzenAlert>
            }
            else
            {
                <RadzenDataGrid Data="@_matches" TItem="MatchDto"
                                AllowPaging="false" AllowSorting="false"
                                GridLines="DataGridGridLines.Horizontal"
                                RowClick="@OnMatchSelected"
                                style="cursor:pointer">
                    <Columns>
                        <RadzenDataGridColumn TItem="MatchDto" Property="MatchNumber" Title="Mapa #" Width="80px" />
                        <RadzenDataGridColumn TItem="MatchDto" Property="RoundName" Title="Ronda" Width="140px" />
                        <RadzenDataGridColumn TItem="MatchDto" Title="Estado" Width="130px">
                            <Template Context="m">
                                <RadzenBadge Text="@m.StatusName" BadgeStyle="@GetMatchBadge(m.Status)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="MatchDto" Title="Equipos" Width="90px">
                            <Template Context="m">
                                @if (m.TeamResults.Count > 0)
                                {<span style="color:var(--rz-success)">@m.TeamResults.Count equipos</span>}
                                else
                                {<span style="color:var(--rz-text-secondary-color)">Sin datos</span>}
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="MatchDto" Property="ResultsConfirmed" Title="Confirmado" Width="110px">
                            <Template Context="m">
                                <RadzenIcon Icon="@(m.ResultsConfirmed ? "check_circle" : "radio_button_unchecked")"
                                            style="@($"color:{(m.ResultsConfirmed ? "var(--rz-success)" : "var(--rz-text-secondary-color)")}")" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenCard>
    }

    @* ── Paso 3: Tabla de resultados ── *@
    @if (_editingMatch != null)
    {
        <RadzenCard>
            <div class="page-header" style="margin-bottom:4px">
                <h3 style="margin:0">
                    Mapa #@_editingMatch.MatchNumber
                    @if (!string.IsNullOrEmpty(_editingMatch.RoundName))
                    {<small style="color:var(--rz-text-secondary-color)"> — @_editingMatch.RoundName</small>}
                </h3>
                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@(() => _editingMatch = null)" />
            </div>

            <small style="color:var(--rz-text-secondary-color);display:block;margin-bottom:16px">
                Llena los datos de cada equipo conforme van reportando kills en Discord. Placement = posición final en el mapa (1er lugar, 2do...).
            </small>

            @if (_loadingTeams)
            {
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
            }
            else if (!_editRows.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
                    No hay equipos inscritos en este torneo. Inscríbelos primero en
                    <RadzenLink Text="Setup del Torneo" Path="@($"/admin/setup/{_selectedTournamentId}")" />.
                </RadzenAlert>
            }
            else
            {
                <div style="overflow-x:auto">
                    <table style="width:100%;border-collapse:collapse;min-width:600px">
                        <thead>
                            <tr style="background:var(--rz-base-background-color)">
                                <th style="text-align:left;padding:10px 12px;border-bottom:2px solid var(--rz-grid-header-border-color)">Equipo</th>
                                <th style="text-align:center;padding:10px 8px;width:100px;border-bottom:2px solid var(--rz-grid-header-border-color)">
                                    Posición
                                    <div style="font-weight:400;font-size:0.75em;color:var(--rz-text-secondary-color)">(1er lugar = 1)</div>
                                </th>
                                <th style="text-align:center;padding:10px 8px;width:100px;border-bottom:2px solid var(--rz-grid-header-border-color)">
                                    Kills
                                    <div style="font-weight:400;font-size:0.75em;color:var(--rz-text-secondary-color)">(total equipo)</div>
                                </th>
                                <th style="text-align:center;padding:10px 8px;width:90px;border-bottom:2px solid var(--rz-grid-header-border-color)">
                                    Muertes
                                </th>
                                <th style="text-align:center;padding:10px 8px;width:100px;border-bottom:2px solid var(--rz-grid-header-border-color)">
                                    Bonus
                                    <div style="font-weight:400;font-size:0.75em;color:var(--rz-text-secondary-color)">(ajuste manual)</div>
                                </th>
                                <th style="text-align:center;padding:10px 8px;width:90px;border-bottom:2px solid var(--rz-grid-header-border-color);color:var(--rz-primary)">
                                    Puntos
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _editRows.OrderBy(r => r.Placement == 0 ? 999 : r.Placement))
                            {
                                <tr style="border-bottom:1px solid var(--rz-grid-header-border-color)">
                                    <td style="padding:8px 12px">
                                        <strong>@row.TeamName</strong>
                                        @if (!string.IsNullOrEmpty(row.TeamTag))
                                        {<small style="color:var(--rz-text-secondary-color)"> [@row.TeamTag]</small>}
                                    </td>
                                    <td style="padding:4px 8px;text-align:center">
                                        <RadzenNumeric @bind-Value="row.Placement" Min="0" Max="150"
                                                       TValue="int" Style="width:70px"
                                                       Change="@(_ => StateHasChanged())" />
                                    </td>
                                    <td style="padding:4px 8px;text-align:center">
                                        <RadzenNumeric @bind-Value="row.Kills" Min="0"
                                                       TValue="int" Style="width:70px"
                                                       Change="@(_ => StateHasChanged())" />
                                    </td>
                                    <td style="padding:4px 8px;text-align:center">
                                        <RadzenNumeric @bind-Value="row.Deaths" Min="0"
                                                       TValue="int" Style="width:70px" />
                                    </td>
                                    <td style="padding:4px 8px;text-align:center">
                                        <RadzenNumeric @bind-Value="row.BonusPoints" Min="-999" Max="999"
                                                       TValue="int" Style="width:80px"
                                                       Change="@(_ => StateHasChanged())" />
                                    </td>
                                    <td style="text-align:center;padding:8px 12px;font-weight:700;font-size:1.1em;color:var(--rz-primary)">
                                        @((_placementMap.TryGetValue(row.Placement, out var pp) ? pp : 0)
                                          + row.Kills * _killPoints
                                          + row.BonusPoints)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <small style="color:var(--rz-text-secondary-color);display:block;margin-top:8px">
                    Puntos = Pts por posición + (kills × @_killPoints) + bonus.
                    Puedes guardar parcialmente y volver a guardar cuando tengas todos los datos.
                </small>

                @if (!string.IsNullOrEmpty(_saveError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="mt-3">@_saveError</RadzenAlert>
                }
                @if (!string.IsNullOrEmpty(_saveSuccess))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" class="mt-3">@_saveSuccess</RadzenAlert>
                }

                <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap">
                    <RadzenButton Text="Guardar y actualizar leaderboard" Icon="save"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Click="@SaveResults" Disabled="@_saving" />
                    <RadzenButton Text="Cancelar" Icon="close" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => _editingMatch = null)" Disabled="@_saving" />
                </div>
            }
        </RadzenCard>
    }
</div>

@code {
    private bool _loadingTournaments = true;
    private bool _loadingMatches = false;
    private bool _loadingTeams = false;
    private bool _saving = false;

    private List<TournamentListDto> _tournaments = new();
    private List<MatchDto> _matches = new();
    private Guid _selectedTournamentId = Guid.Empty;
    private MatchDto? _editingMatch;
    private List<EditRow> _editRows = new();
    private Dictionary<int, int> _placementMap = new();
    private int _killPoints = 1;
    private string? _saveError;
    private string? _saveSuccess;

    protected override async Task OnInitializedAsync()
    {
        var result = await TournamentService.GetTournamentsAsync(new TournamentQueryDto
        {
            PageNumber = 1, PageSize = 100
        });
        if (result.IsSuccess)
            _tournaments = result.Value.Items.ToList();
        _loadingTournaments = false;
    }

    private async Task OnTournamentSelected(object? _)
    {
        _editingMatch = null;
        _matches.Clear();
        _placementMap.Clear();
        if (_selectedTournamentId == Guid.Empty) return;

        _loadingMatches = true;

        // Load scoring config from tournament
        var tResult = await TournamentService.GetTournamentByIdAsync(_selectedTournamentId);
        if (tResult.IsSuccess)
        {
            _killPoints = tResult.Value.KillPoints;
            try
            {
                _placementMap = System.Text.Json.JsonSerializer
                    .Deserialize<Dictionary<int, int>>(tResult.Value.PlacementPointsJson)
                    ?? new();
            }
            catch { _placementMap = new(); }
        }

        var result = await MatchService.GetMatchesByTournamentAsync(_selectedTournamentId);
        if (result.IsSuccess)
            _matches = result.Value.ToList();

        _loadingMatches = false;
    }

    private async Task OnMatchSelected(DataGridRowMouseEventArgs<MatchDto> args)
    {
        _editingMatch = args.Data;
        _saveError = null;
        _saveSuccess = null;

        if (args.Data.TeamResults.Any())
        {
            // Match ya tiene resultados → cargar los existentes
            _editRows = args.Data.TeamResults.Select(tr => new EditRow
            {
                TeamId      = tr.TeamId,
                TeamName    = tr.TeamName,
                TeamTag     = tr.TeamTag,
                Placement   = tr.Placement,
                Kills       = tr.Kills,
                Deaths      = tr.Deaths,
                BonusPoints = tr.BonusPoints,
            }).ToList();
        }
        else
        {
            // Match nuevo → cargar equipos inscritos en el torneo como filas vacías
            _loadingTeams = true;
            StateHasChanged();

            var teamsResult = await TeamService.GetTeamsWithTournamentStatusAsync(_selectedTournamentId);
            if (teamsResult.IsSuccess)
            {
                _editRows = teamsResult.Value
                    .Where(t => t.IsRegistered)
                    .Select(t => new EditRow
                    {
                        TeamId   = t.TeamId,
                        TeamName = t.TeamName,
                        TeamTag  = t.TeamTag,
                    })
                    .ToList();
            }
            _loadingTeams = false;
        }
    }

    private async Task SaveResults()
    {
        if (_editingMatch == null) return;
        _saving = true;
        _saveError = null;
        _saveSuccess = null;

        var dto = new SubmitMatchResultsDto
        {
            TeamResults = _editRows.Select(r => new TeamResultDto
            {
                TeamId      = r.TeamId,
                Placement   = r.Placement > 0 ? r.Placement : 1,
                Kills       = r.Kills,
                Deaths      = r.Deaths,
                BonusPoints = r.BonusPoints,
            }).ToList(),
            PlayerStats = new()
        };

        var result = await MatchService.SubmitMatchResultsAsync(_editingMatch.Id, dto);
        if (result.IsSuccess)
        {
            _editingMatch = result.Value;
            _saveSuccess = $"✓ Mapa #{_editingMatch.MatchNumber} guardado. Leaderboard actualizado.";
            await OnTournamentSelected(null);
            // Re-cargar filas con los datos guardados
            _editRows = result.Value.TeamResults.Select(tr => new EditRow
            {
                TeamId      = tr.TeamId,
                TeamName    = tr.TeamName,
                TeamTag     = tr.TeamTag,
                Placement   = tr.Placement,
                Kills       = tr.Kills,
                Deaths      = tr.Deaths,
                BonusPoints = tr.BonusPoints,
            }).ToList();
        }
        else
        {
            _saveError = result.Error;
        }
        _saving = false;
    }

    private BadgeStyle GetMatchBadge(WarzoneTournament.Domain.Enums.MatchStatus s) => s switch
    {
        WarzoneTournament.Domain.Enums.MatchStatus.InProgress     => BadgeStyle.Danger,
        WarzoneTournament.Domain.Enums.MatchStatus.Completed      => BadgeStyle.Success,
        WarzoneTournament.Domain.Enums.MatchStatus.WaitingEvidence => BadgeStyle.Warning,
        WarzoneTournament.Domain.Enums.MatchStatus.UnderReview    => BadgeStyle.Warning,
        WarzoneTournament.Domain.Enums.MatchStatus.Cancelled      => BadgeStyle.Secondary,
        _ => BadgeStyle.Light
    };

    private class EditRow
    {
        public Guid TeamId      { get; set; }
        public string TeamName  { get; set; } = string.Empty;
        public string? TeamTag  { get; set; }
        public int Placement    { get; set; } = 0;
        public int Kills        { get; set; } = 0;
        public int Deaths       { get; set; } = 0;
        public int BonusPoints  { get; set; } = 0;
    }
}
