@page "/admin/manual-points"
@using WarzoneTournament.Application.Common.Interfaces
@using WarzoneTournament.Application.DTOs.Match
@using WarzoneTournament.Application.DTOs.Round
@using WarzoneTournament.Application.DTOs.Tournament
@using WarzoneTournament.Domain.Enums
@inject ITournamentService TournamentService
@inject ITeamService TeamService
@inject IMatchService MatchService
@inject IRoundService RoundService
@inject NavigationManager NavManager

<PageTitle>Ingresar Kills - Admin</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Ingresar Kills</h1>
        <RadzenButton Text="Admin" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => NavManager.NavigateTo("/admin"))" />
    </div>

    @* ── Selección de torneo ── *@
    <RadzenCard class="mb-3">
        @if (_loadingTournaments)
        {
            <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
        }
        else
        {
            <RadzenDropDown @bind-Value="_selectedTournamentId"
                            Data="@_tournaments"
                            TextProperty="Name"
                            ValueProperty="Id"
                            Placeholder="-- Selecciona el torneo --"
                            Style="width:100%;max-width:500px"
                            Change="@OnTournamentSelected" />
        }
    </RadzenCard>

    @* ── Lista de mapas ── *@
    @if (_selectedTournamentId != Guid.Empty)
    {
        <RadzenCard class="mb-3">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px">
                <h3 style="margin:0">
                    Mapas
                    @if (_matches.Any())
                    {<small style="font-weight:400;color:var(--rz-text-secondary-color)"> (@_matches.Count jugados)</small>}
                </h3>
                <RadzenButton Text="Agregar Mapa" Icon="add" ButtonStyle="ButtonStyle.Primary"
                              Click="@AddMap" Disabled="@_addingMap" />
            </div>

            @if (_loadingMatches || _addingMap)
            {
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
            }
            else if (!_matches.Any())
            {
                <div style="text-align:center;padding:24px;color:var(--rz-text-secondary-color)">
                    <div style="font-size:2em;margin-bottom:8px">🗺️</div>
                    <div>Sin mapas. Pulsa <strong>Agregar Mapa</strong> para empezar.</div>
                </div>
            }
            else
            {
                <div style="display:flex;flex-wrap:wrap;gap:8px">
                    @foreach (var m in _matches.OrderBy(x => x.MatchNumber))
                    {
                        var isSelected = _editingMatch?.Id == m.Id;
                        <div @onclick="@(() => SelectMatch(m))"
                             style="cursor:pointer;padding:10px 18px;border-radius:8px;border:2px solid @(isSelected ? "var(--rz-primary)" : "var(--rz-grid-header-border-color)");background:@(isSelected ? "var(--rz-primary-light)" : "transparent");display:flex;flex-direction:column;align-items:center;min-width:90px;transition:all 0.15s">
                            <span style="font-weight:700;font-size:1.1em;color:@(isSelected ? "var(--rz-primary)" : "inherit")">Mapa @m.MatchNumber</span>
                            <RadzenBadge Text="@(m.ResultsConfirmed ? "✓" : (m.TeamResults.Count > 0 ? "Parcial" : "Vacío"))"
                                         BadgeStyle="@(m.ResultsConfirmed ? BadgeStyle.Success : (m.TeamResults.Count > 0 ? BadgeStyle.Warning : BadgeStyle.Light))"
                                         style="margin-top:4px;font-size:0.75em" />
                        </div>
                    }
                </div>
            }
        </RadzenCard>
    }

    @* ── Formulario de kills por jugador ── *@
    @if (_editingMatch != null)
    {
        <RadzenCard>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;flex-wrap:wrap;gap:8px">
                <h3 style="margin:0">Mapa @_editingMatch.MatchNumber — Kills por Jugador</h3>
                <div style="display:flex;gap:8px">
                    @if (!_editingMatch.ResultsConfirmed && _editingMatch.TeamResults.Any())
                    {
                        <RadzenButton Text="Confirmar" Icon="check_circle" ButtonStyle="ButtonStyle.Success"
                                      Size="ButtonSize.Small" Click="@ConfirmResults" Disabled="@_saving" />
                    }
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => { _editingMatch = null; _saveError = null; _saveSuccess = null; })" />
                </div>
            </div>

            <small style="color:var(--rz-text-secondary-color);display:block;margin-bottom:16px">
                Ingresa las kills de cada jugador según el screenshot de Discord.
                Posición = lugar del equipo (1 = 1er lugar). Puedes guardar parcialmente.
            </small>

            @if (_loadingTeams)
            {
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
            }
            else if (!_editTeams.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
                    No hay equipos inscritos en este torneo.
                    <RadzenLink Text="Configura el torneo" Path="@($"/admin/setup/{_selectedTournamentId}")" />.
                </RadzenAlert>
            }
            else
            {
                @foreach (var team in _editTeams.OrderBy(t => t.Placement == 0 ? 999 : t.Placement))
                {
                    <div style="margin-bottom:16px;border:1px solid var(--rz-grid-header-border-color);border-radius:8px;overflow:hidden">
                        @* Cabecera del equipo *@
                        <div style="background:var(--rz-base-background-color);padding:10px 14px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
                            <strong style="font-size:1.05em">@team.TeamName</strong>
                            @if (!string.IsNullOrEmpty(team.TeamTag))
                            {<small style="color:var(--rz-text-secondary-color)">[@team.TeamTag]</small>}
                            <div style="display:flex;align-items:center;gap:8px;margin-left:auto">
                                <span style="font-size:0.85em;color:var(--rz-text-secondary-color)">Posición:</span>
                                <RadzenNumeric @bind-Value="team.Placement" Min="0" Max="150" TValue="int" Style="width:68px"
                                               Change="@(_ => StateHasChanged())" />
                                <span style="font-size:0.85em;color:var(--rz-text-secondary-color);margin-left:8px">Bonus:</span>
                                <RadzenNumeric @bind-Value="team.BonusPoints" Min="-999" Max="999" TValue="int" Style="width:68px"
                                               Change="@(_ => StateHasChanged())" />
                            </div>
                        </div>

                        @* Filas de jugadores *@
                        @if (team.Players.Any())
                        {
                            <table style="width:100%;border-collapse:collapse">
                                <thead>
                                    <tr style="background:var(--rz-base-background-color)">
                                        <th style="text-align:left;padding:6px 14px;font-size:0.85em;color:var(--rz-text-secondary-color);font-weight:400;border-bottom:1px solid var(--rz-grid-header-border-color)">Jugador</th>
                                        <th style="text-align:center;padding:6px 8px;width:90px;font-size:0.85em;color:var(--rz-text-secondary-color);font-weight:400;border-bottom:1px solid var(--rz-grid-header-border-color)">Kills</th>
                                        <th style="text-align:center;padding:6px 8px;width:90px;font-size:0.85em;color:var(--rz-primary);font-weight:400;border-bottom:1px solid var(--rz-grid-header-border-color)">Pts</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in team.Players)
                                    {
                                        <tr style="border-bottom:1px solid var(--rz-grid-header-border-color)">
                                            <td style="padding:6px 14px">@p.Username</td>
                                            <td style="padding:4px 8px;text-align:center">
                                                <RadzenNumeric @bind-Value="p.Kills" Min="0" TValue="int" Style="width:68px"
                                                               Change="@(_ => StateHasChanged())" />
                                            </td>
                                            <td style="text-align:center;padding:6px 8px;font-weight:600;color:var(--rz-primary)">
                                                @CalcPlayerPoints(team, p)
                                            </td>
                                        </tr>
                                    }
                                    @* Total del equipo *@
                                    <tr style="background:var(--rz-base-background-color)">
                                        <td style="padding:6px 14px;font-weight:600">Total equipo</td>
                                        <td style="text-align:center;padding:6px 8px;font-weight:600">@team.Players.Sum(p => p.Kills)</td>
                                        <td style="text-align:center;padding:6px 8px;font-weight:700;color:var(--rz-primary)">@CalcTeamPoints(team)</td>
                                    </tr>
                                </tbody>
                            </table>
                        }
                        else
                        {
                            @* Sin jugadores registrados → entrada directa por equipo *@
                            <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;flex-wrap:wrap">
                                <span style="color:var(--rz-text-secondary-color);font-size:0.85em">Sin jugadores registrados. Kills del equipo:</span>
                                <RadzenNumeric @bind-Value="team.DirectKills" Min="0" TValue="int" Style="width:68px"
                                               Change="@(_ => StateHasChanged())" />
                                <span style="font-weight:700;color:var(--rz-primary)">= @CalcTeamPoints(team) pts</span>
                            </div>
                        }
                    </div>
                }

                <small style="color:var(--rz-text-secondary-color);display:block;margin-top:4px">
                    Pts = kills × multiplicador por posición + bonus.
                </small>

                @if (!string.IsNullOrEmpty(_saveError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="mt-3">@_saveError</RadzenAlert>
                }
                @if (!string.IsNullOrEmpty(_saveSuccess))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" class="mt-3">@_saveSuccess</RadzenAlert>
                }

                <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap">
                    <RadzenButton Text="Guardar" Icon="save" ButtonStyle="ButtonStyle.Primary"
                                  Click="@SaveResults" Disabled="@_saving" />
                    <RadzenButton Text="Cerrar" Icon="close" ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => { _editingMatch = null; _saveError = null; _saveSuccess = null; })"
                                  Disabled="@_saving" />
                </div>
            }
        </RadzenCard>
    }
</div>

@code {
    private bool _loadingTournaments = true;
    private bool _loadingMatches = false;
    private bool _loadingTeams = false;
    private bool _saving = false;
    private bool _addingMap = false;

    private List<TournamentListDto> _tournaments = new();
    private List<MatchDto> _matches = new();
    private Guid _selectedTournamentId = Guid.Empty;
    private MatchDto? _editingMatch;
    private List<EditTeam> _editTeams = new();
    private Dictionary<int, double> _placementMap = new();
    private string? _saveError;
    private string? _saveSuccess;

    protected override async Task OnInitializedAsync()
    {
        var result = await TournamentService.GetTournamentsAsync(new TournamentQueryDto { PageNumber = 1, PageSize = 100 });
        if (result.IsSuccess)
            _tournaments = result.Value.Items.ToList();
        _loadingTournaments = false;
    }

    private async Task OnTournamentSelected(object? _)
    {
        _editingMatch = null;
        _matches.Clear();
        _placementMap.Clear();
        if (_selectedTournamentId == Guid.Empty) return;

        _loadingMatches = true;

        var tResult = await TournamentService.GetTournamentByIdAsync(_selectedTournamentId);
        if (tResult.IsSuccess)
        {
            try { _placementMap = System.Text.Json.JsonSerializer.Deserialize<Dictionary<int, double>>(tResult.Value.PlacementPointsJson) ?? new(); }
            catch { _placementMap = new(); }
        }

        var result = await MatchService.GetMatchesByTournamentAsync(_selectedTournamentId);
        if (result.IsSuccess)
            _matches = result.Value.ToList();

        _loadingMatches = false;
    }

    private async Task AddMap()
    {
        _addingMap = true;
        _saveError = null;
        _saveSuccess = null;

        Guid roundId;
        var roundsResult = await RoundService.GetRoundsByTournamentAsync(_selectedTournamentId);
        if (roundsResult.IsSuccess && roundsResult.Value.Any())
        {
            roundId = roundsResult.Value.First().Id;
        }
        else
        {
            var newRound = await RoundService.CreateRoundAsync(new CreateRoundDto
            {
                TournamentId = _selectedTournamentId,
                RoundNumber  = 1,
                Name         = "General"
            });
            if (!newRound.IsSuccess)
            {
                _saveError = "No se pudo crear la ronda: " + newRound.Error;
                _addingMap = false;
                return;
            }
            roundId = newRound.Value.Id;
        }

        int nextNumber = _matches.Any() ? _matches.Max(m => m.MatchNumber) + 1 : 1;

        var matchResult = await MatchService.CreateMatchAsync(new CreateMatchDto
        {
            RoundId      = roundId,
            TournamentId = _selectedTournamentId,
            MatchNumber  = nextNumber
        });

        if (matchResult.IsSuccess)
        {
            _matches.Add(matchResult.Value);
            _matches = _matches.OrderBy(m => m.MatchNumber).ToList();
            await SelectMatch(matchResult.Value);
        }
        else
        {
            _saveError = "No se pudo crear el mapa: " + matchResult.Error;
        }

        _addingMap = false;
    }

    private async Task SelectMatch(MatchDto match)
    {
        _editingMatch = match;
        _saveError = null;
        _saveSuccess = null;
        _loadingTeams = true;
        StateHasChanged();

        // Load all registered teams with their players
        var teamsResult = await TeamService.GetTeamsWithTournamentStatusAsync(_selectedTournamentId);
        if (teamsResult.IsSuccess)
        {
            var registeredTeams = teamsResult.Value.Where(t => t.IsRegistered).ToList();

            _editTeams = registeredTeams.Select(t =>
            {
                var existing = match.TeamResults.FirstOrDefault(tr => tr.TeamId == t.TeamId);
                return new EditTeam
                {
                    TeamId      = t.TeamId,
                    TeamName    = t.TeamName,
                    TeamTag     = t.TeamTag,
                    Placement   = existing?.Placement ?? 0,
                    BonusPoints = existing?.BonusPoints ?? 0,
                    DirectKills = existing?.Kills ?? 0,
                    Players     = t.Players.Select(p => new EditPlayer
                    {
                        PlayerId = p.PlayerId,
                        Username = p.Username,
                        Kills    = match.PlayerStats
                                       .FirstOrDefault(ps => ps.PlayerId == p.PlayerId)?.Kills ?? 0
                    }).ToList()
                };
            }).ToList();
        }

        _loadingTeams = false;
    }

    private async Task SaveResults()
    {
        if (_editingMatch == null) return;

        var validationError = ValidatePlacements();
        if (validationError is not null)
        {
            _saveError = validationError;
            return;
        }

        _saving = true;
        _saveError = null;
        _saveSuccess = null;

        var teamResults = _editTeams.Select(t => new TeamResultDto
        {
            TeamId      = t.TeamId,
            Placement   = t.Placement > 0 ? t.Placement : 1,
            Kills       = t.Players.Any() ? t.Players.Sum(p => p.Kills) : t.DirectKills,
            Deaths      = 0,
            BonusPoints = t.BonusPoints,
        }).ToList();

        var playerStats = _editTeams
            .Where(t => t.Players.Any())
            .SelectMany(t => t.Players.Select(p => new PlayerStatSubmitDto
            {
                PlayerId = p.PlayerId,
                TeamId   = t.TeamId,
                Kills    = p.Kills,
                Deaths   = 0
            })).ToList();

        var dto = new SubmitMatchResultsDto
        {
            TeamResults = teamResults,
            PlayerStats = playerStats
        };

        var result = await MatchService.SubmitMatchResultsAsync(_editingMatch.Id, dto);
        if (result.IsSuccess)
        {
            var idx = _matches.FindIndex(m => m.Id == result.Value.Id);
            if (idx >= 0) _matches[idx] = result.Value;
            _editingMatch = result.Value;
            _saveSuccess = $"✓ Mapa {_editingMatch.MatchNumber} guardado. Leaderboard actualizado.";
        }
        else
        {
            _saveError = result.Error;
        }
        _saving = false;
    }

    private async Task ConfirmResults()
    {
        if (_editingMatch == null) return;
        _saving = true;
        var result = await MatchService.ConfirmMatchResultsAsync(_editingMatch.Id);
        if (result.IsSuccess)
        {
            var idx = _matches.FindIndex(m => m.Id == result.Value.Id);
            if (idx >= 0) _matches[idx] = result.Value;
            _editingMatch = result.Value;
            _saveSuccess = $"✓ Mapa {_editingMatch.MatchNumber} confirmado.";
        }
        else
        {
            _saveError = result.Error;
        }
        _saving = false;
    }

    private string? ValidatePlacements()
    {
        var placements = _editTeams.Select(t => t.Placement).ToList();
        int teamCount  = _editTeams.Count;

        if (placements.Any(p => p <= 0))
            return "Todos los equipos deben tener una posición mayor a 0.";

        if (placements.Any(p => p > teamCount))
            return $"La posición máxima es {teamCount} (número de equipos).";

        var duplicates = placements.GroupBy(p => p).Where(g => g.Count() > 1).Select(g => g.Key).ToList();
        if (duplicates.Any())
            return $"Posición duplicada: #{string.Join(", #", duplicates)}. Cada equipo debe tener una posición única.";

        return null;
    }

    private double CalcPlayerPoints(EditTeam team, EditPlayer player)
    {
        var mult = _placementMap.TryGetValue(team.Placement, out var v) ? v : 1.0;
        return Math.Round(player.Kills * mult, 2);
    }

    private double CalcTeamPoints(EditTeam team)
    {
        var mult = _placementMap.TryGetValue(team.Placement, out var v) ? v : 1.0;
        var kills = team.Players.Any() ? team.Players.Sum(p => p.Kills) : team.DirectKills;
        return Math.Round(kills * mult + team.BonusPoints, 2);
    }

    private class EditTeam
    {
        public Guid TeamId       { get; set; }
        public string TeamName   { get; set; } = string.Empty;
        public string? TeamTag   { get; set; }
        public int Placement     { get; set; } = 0;
        public int BonusPoints   { get; set; } = 0;
        public int DirectKills   { get; set; } = 0;
        public List<EditPlayer> Players { get; set; } = new();
    }

    private class EditPlayer
    {
        public Guid PlayerId     { get; set; }
        public string Username   { get; set; } = string.Empty;
        public int Kills         { get; set; } = 0;
    }
}
