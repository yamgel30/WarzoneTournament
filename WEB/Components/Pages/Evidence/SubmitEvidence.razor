@page "/submit-evidence"
@rendermode InteractiveServer
@using WarzoneTournament.Application.Common.Interfaces
@using WarzoneTournament.Application.DTOs.Evidence
@using WarzoneTournament.Application.DTOs.Player
@using WarzoneTournament.Domain.Enums
@using WarzoneTournament.Infrastructure.BackgroundJobs
@using Hangfire
@inject IPlayerService PlayerService
@inject IEvidenceService EvidenceService
@inject IFileStorageService FileStorage
@inject IBackgroundJobClient BackgroundJobs

<PageTitle>Subir Evidencia - Warzone Tournament</PageTitle>

<div class="page-container" style="max-width:660px;margin:0 auto">
    <div class="page-header">
        <h1 class="page-title">Subir Evidencia</h1>
    </div>
    <p style="color:var(--rz-text-secondary-color);margin-bottom:20px">
        Sube las capturas de pantalla de tu partida para registrar los resultados oficialmente.
    </p>

    @* ── Step 1: Identificarse ─────────────────────────────────────────────── *@
    <RadzenCard class="mb-3">
        <h3 style="margin-bottom:14px">1. Identifícate con tu Discord ID</h3>
        <p style="font-size:0.88em;color:var(--rz-text-secondary-color);margin-bottom:12px">
            Encuentra tu Discord ID: abre Discord → Ajustes → Avanzado → activa "Modo desarrollador"
            → clic derecho en tu perfil → "Copiar ID de usuario".
        </p>
        <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
            <div style="flex:1;min-width:220px">
                <RadzenLabel Text="Discord ID" />
                <RadzenTextBox @bind-Value="_discordId" Placeholder="ej: 123456789012345678"
                               Style="width:100%;margin-top:6px"
                               @onkeydown="@(async e => { if (e.Key == "Enter") await LookupPlayer(); })" />
            </div>
            <RadzenButton Text="Buscar" Icon="search" ButtonStyle="ButtonStyle.Primary"
                          Click="@LookupPlayer"
                          Disabled="@(_busy || string.IsNullOrWhiteSpace(_discordId))" />
        </div>
        @if (!string.IsNullOrEmpty(_lookupError))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="mt-2">
                @_lookupError
            </RadzenAlert>
        }
    </RadzenCard>

    @* ── Context found ─────────────────────────────────────────────────────── *@
    @if (_context is not null)
    {
        <RadzenCard class="mb-3" style="border-left:4px solid var(--rz-success)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">
                <div>
                    <div style="font-size:1.05em;font-weight:700">@_context.PlayerName</div>
                    <div style="color:var(--rz-text-secondary-color);margin-top:2px">
                        Equipo: <strong>@_context.TeamName</strong> &nbsp;·&nbsp;
                        Torneo: <strong>@_context.TournamentName</strong>
                    </div>
                    <div style="margin-top:8px">
                        @if (_context.ActiveMatchId.HasValue)
                        {
                            <RadzenBadge Text="@($"Mapa #{_context.ActiveMatchNumber} activo")"
                                         BadgeStyle="BadgeStyle.Danger" />
                        }
                        else
                        {
                            <RadzenBadge Text="No hay mapa activo en este momento" BadgeStyle="BadgeStyle.Secondary" />
                        }
                    </div>
                </div>
                <span style="color:var(--rz-success);font-size:1.5em">✓</span>
            </div>
        </RadzenCard>

        @* ── Step 2: Upload photos (only if active match) ─────────────────── *@
        @if (_context.ActiveMatchId.HasValue)
        {
            <RadzenCard class="mb-3">
                <h3 style="margin-bottom:14px">2. Sube las capturas del mapa</h3>
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" class="mb-3">
                    Necesitas <strong>dos capturas</strong>:
                    la posición final del equipo y la tabla de kills por jugador.
                    Formatos aceptados: JPG, PNG, WEBP. Máximo 10 MB cada una.
                </RadzenAlert>

                @* File 1: Placement *@
                <div style="margin-bottom:18px;padding:14px;border:1px solid var(--rz-border-disabled-color);border-radius:6px">
                    <div style="font-weight:600;margin-bottom:8px">
                        📍 Captura 1 — Posición final del equipo
                    </div>
                    <InputFile id="file-placement" OnChange="@(e => HandleFile(e, 0))"
                               accept="image/jpeg,image/png,image/webp" style="display:none" />
                    <label for="file-placement" style="cursor:pointer;display:inline-block">
                        <RadzenButton Text="@(_files[0] != null ? _files[0]!.Name : "Seleccionar imagen…")"
                                      Icon="@(_files[0] != null ? "check_circle" : "image")"
                                      ButtonStyle="@(_files[0] != null ? ButtonStyle.Success : ButtonStyle.Light)"
                                      Size="ButtonSize.Small" />
                    </label>
                    @if (_fileErrors[0] is not null)
                    {<div style="color:var(--rz-danger);font-size:0.85em;margin-top:6px">@_fileErrors[0]</div>}
                </div>

                @* File 2: Scoreboard *@
                <div style="margin-bottom:18px;padding:14px;border:1px solid var(--rz-border-disabled-color);border-radius:6px">
                    <div style="font-weight:600;margin-bottom:8px">
                        📊 Captura 2 — Tabla de kills por jugador (scoreboard)
                    </div>
                    <InputFile id="file-scoreboard" OnChange="@(e => HandleFile(e, 1))"
                               accept="image/jpeg,image/png,image/webp" style="display:none" />
                    <label for="file-scoreboard" style="cursor:pointer;display:inline-block">
                        <RadzenButton Text="@(_files[1] != null ? _files[1]!.Name : "Seleccionar imagen…")"
                                      Icon="@(_files[1] != null ? "check_circle" : "image")"
                                      ButtonStyle="@(_files[1] != null ? ButtonStyle.Success : ButtonStyle.Light)"
                                      Size="ButtonSize.Small" />
                    </label>
                    @if (_fileErrors[1] is not null)
                    {<div style="color:var(--rz-danger);font-size:0.85em;margin-top:6px">@_fileErrors[1]</div>}
                </div>

                @if (!string.IsNullOrEmpty(_submitError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="mb-2">
                        @_submitError
                    </RadzenAlert>
                }

                <RadzenButton Text="Enviar evidencia" Icon="send" ButtonStyle="ButtonStyle.Primary"
                              Click="@SubmitEvidence"
                              Disabled="@(_busy || _files[0] == null || _files[1] == null)" />
                @if (_busy)
                {
                    <span style="margin-left:12px;color:var(--rz-text-secondary-color);font-size:0.9em">
                        Subiendo imágenes…
                    </span>
                }
            </RadzenCard>
        }
    }

    @* ── Success ───────────────────────────────────────────────────────────── *@
    @if (_submitted)
    {
        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" class="mb-3">
            <strong>✓ Evidencia enviada correctamente.</strong><br />
            Las imágenes quedaron registradas para el Mapa #@_submittedMatchNumber.
            El administrador las revisará y confirmará los resultados.
            @if (_ocrQueued)
            {<span> El sistema procesará las imágenes automáticamente en segundo plano.</span>}
        </RadzenAlert>

        <RadzenButton Text="Enviar evidencia de otro mapa" Icon="refresh"
                      ButtonStyle="ButtonStyle.Light" Click="@Reset" />
    }
</div>

@code {
    private string? _discordId;
    private string? _lookupError;
    private string? _submitError;
    private bool _busy;
    private bool _submitted;
    private bool _ocrQueued;
    private int _submittedMatchNumber;
    private PlayerContextDto? _context;

    private readonly IBrowserFile?[] _files = new IBrowserFile?[2];
    private readonly string?[] _fileErrors = new string?[2];

    private async Task LookupPlayer()
    {
        if (string.IsNullOrWhiteSpace(_discordId)) return;
        _busy = true;
        _lookupError = null;
        _context = null;
        _submitted = false;

        var playerResult = await PlayerService.GetPlayerByDiscordIdAsync(_discordId.Trim());
        if (playerResult.IsFailure)
        {
            _lookupError = "No se encontró ningún jugador con ese Discord ID. Verifica que estés registrado en el sistema.";
            _busy = false;
            return;
        }

        var contextResult = await PlayerService.GetPlayerTournamentContextAsync(playerResult.Value.Id);
        if (contextResult.IsFailure)
        {
            _lookupError = contextResult.Error ?? "No hay torneo activo para tu equipo.";
            _busy = false;
            return;
        }

        _context = contextResult.Value;
        _busy = false;
    }

    private void HandleFile(InputFileChangeEventArgs e, int slot)
    {
        _fileErrors[slot] = null;
        var file = e.File;

        if (file.Size > 10L * 1024 * 1024)
        {
            _fileErrors[slot] = "El archivo excede el límite de 10 MB.";
            _files[slot] = null;
            return;
        }

        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
        {
            _fileErrors[slot] = "Solo se permiten imágenes JPG, PNG o WEBP.";
            _files[slot] = null;
            return;
        }

        _files[slot] = file;
    }

    private async Task SubmitEvidence()
    {
        if (_context?.ActiveMatchId is null || _files[0] is null || _files[1] is null) return;

        _busy = true;
        _submitError = null;
        var matchId = _context.ActiveMatchId.Value;
        var evidenceIds = new List<Guid>();

        for (int i = 0; i < 2; i++)
        {
            var file = _files[i]!;
            try
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: 10L * 1024 * 1024);
                var url = await FileStorage.UploadFileAsync(stream, file.Name, file.ContentType);

                var dto = new SubmitEvidenceDto
                {
                    MatchId = matchId,
                    SubmittedByTeamId = _context.TeamId,
                    SubmittedByPlayerId = _context.PlayerId,
                    ImageUrl = url,
                    OriginalFileName = file.Name,
                    FileSizeBytes = file.Size,
                    MimeType = file.ContentType,
                    SourceType = EvidenceSourceType.ManualUpload
                };

                var result = await EvidenceService.SubmitEvidenceAsync(dto);
                if (result.IsFailure)
                {
                    _submitError = result.Error;
                    _busy = false;
                    return;
                }
                evidenceIds.Add(result.Value.Id);
            }
            catch (Exception ex)
            {
                _submitError = $"Error al subir la imagen {i + 1}: {ex.Message}";
                _busy = false;
                return;
            }
        }

        // Enqueue OCR background jobs — if Tesseract not configured the job returns immediately
        foreach (var eid in evidenceIds)
        {
            try
            {
                BackgroundJobs.Enqueue<OcrBackgroundJob>(job => job.ProcessEvidenceOcrAsync(eid, matchId));
                _ocrQueued = true;
            }
            catch { /* Hangfire not available — OCR will be skipped */ }
        }

        _submittedMatchNumber = _context.ActiveMatchNumber;
        _submitted = true;
        Reset(clearSubmitted: false);
        _busy = false;
    }

    private void Reset(bool clearSubmitted = true)
    {
        _context = null;
        _discordId = null;
        _lookupError = null;
        _submitError = null;
        _files[0] = null;
        _files[1] = null;
        _fileErrors[0] = null;
        _fileErrors[1] = null;
        if (clearSubmitted) _submitted = false;
    }
}
