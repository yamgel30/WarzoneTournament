@page "/leaderboard"
@page "/leaderboard/{TournamentId:guid}"
@using WarzoneTournament.Application.Common.Interfaces
@using WarzoneTournament.Application.DTOs.Leaderboard
@using WarzoneTournament.Application.DTOs.Tournament
@using Microsoft.AspNetCore.SignalR.Client
@inject ILeaderboardService LeaderboardService
@inject ITournamentService TournamentService
@inject NavigationManager NavManager
@implements IAsyncDisposable

<PageTitle>Live Leaderboard - Warzone</PageTitle>

<div class="leaderboard-page">
    <div class="page-header">
        <h1 class="page-title">
            Live Leaderboard
            @if (_isConnected)
            {
                <span class="live-indicator">● LIVE</span>
            }
        </h1>
        <div class="leaderboard-controls">
            <RadzenDropDown @bind-Value="_selectedTournamentId"
                            Data="@_tournaments"
                            TextProperty="Name" ValueProperty="Id"
                            Placeholder="Select Tournament..."
                            Style="width:280px"
                            Change="@OnTournamentChanged" />
            <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light"
                          Click="@RefreshLeaderboard" title="Refresh" />
        </div>
    </div>

    @if (_selectedTournamentId == Guid.Empty)
    {
        <div class="empty-state">
            <div class="empty-state__icon">🏆</div>
            <h3>Select a Tournament</h3>
            <p>Choose a tournament from the dropdown to view its live leaderboard.</p>
        </div>
    }
    else if (_loading)
    {
        <LoadingSpinner />
    }
    else if (!_leaderboard.Any())
    {
        <div class="empty-state">
            <div class="empty-state__icon">📊</div>
            <h3>No Results Yet</h3>
            <p>Matches haven't started or no results have been submitted.</p>
        </div>
    }
    else
    {
        <div class="leaderboard-container">
            <div class="leaderboard-table-header">
                <span class="col-rank">Rank</span>
                <span class="col-team">Team</span>
                <span class="col-pts">Total Pts</span>
                <span class="col-kills">Kills</span>
                <span class="col-place-pts">Placement Pts</span>
                <span class="col-kill-pts">Kill Pts</span>
                <span class="col-matches">Matches</span>
                <span class="col-best">Best Place</span>
            </div>

            @foreach (var entry in _leaderboard)
            {
                <div class="leaderboard-row @GetRowClass(entry.Rank)">
                    <div class="col-rank">
                        <div class="rank-badge rank-@(entry.Rank <= 3 ? entry.Rank.ToString() : "other")">
                            @if (entry.Rank == 1) { <span>🥇</span> }
                            else if (entry.Rank == 2) { <span>🥈</span> }
                            else if (entry.Rank == 3) { <span>🥉</span> }
                            else { <span>@entry.Rank</span> }
                        </div>
                    </div>
                    <div class="col-team">
                        @if (!string.IsNullOrEmpty(entry.TeamLogoUrl))
                        {
                            <img src="@entry.TeamLogoUrl" alt="@entry.TeamName" class="team-logo-xs" />
                        }
                        <div class="team-name-info">
                            @if (!string.IsNullOrEmpty(entry.TeamTag))
                            {
                                <span class="team-tag">[<span>@entry.TeamTag</span>]</span>
                            }
                            <span class="team-name">@entry.TeamName</span>
                        </div>
                        @if (entry.IsEliminated)
                        {
                            <RadzenBadge Text="OUT" BadgeStyle="BadgeStyle.Danger" />
                        }
                        else if (entry.CheckedIn)
                        {
                            <RadzenBadge Text="✓" BadgeStyle="BadgeStyle.Success" />
                        }
                    </div>
                    <div class="col-pts points-total">@entry.TotalPoints</div>
                    <div class="col-kills">@entry.TotalKills</div>
                    <div class="col-place-pts">@entry.TotalPlacementPoints</div>
                    <div class="col-kill-pts">@entry.TotalKillPoints</div>
                    <div class="col-matches">@entry.MatchesPlayed</div>
                    <div class="col-best">
                        @if (entry.BestPlacement > 0)
                        {
                            <span class="placement-value">#@entry.BestPlacement</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Guid TournamentId { get; set; }

    private bool _loading = false;
    private bool _isConnected = false;
    private List<LeaderboardEntryDto> _leaderboard = new();
    private List<TournamentListDto> _tournaments = new();
    private Guid _selectedTournamentId;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadTournamentsAsync();

        if (TournamentId != Guid.Empty)
        {
            _selectedTournamentId = TournamentId;
            await LoadLeaderboardAsync();
        }

        await ConnectToSignalRAsync();
    }

    private async Task LoadTournamentsAsync()
    {
        var result = await TournamentService.GetTournamentsAsync(new TournamentQueryDto { PageSize = 50 });
        if (result.IsSuccess)
            _tournaments = result.Value.Items.ToList();
    }

    private async Task LoadLeaderboardAsync()
    {
        if (_selectedTournamentId == Guid.Empty) return;
        _loading = true;
        try
        {
            var result = await LeaderboardService.GetTournamentLeaderboardAsync(_selectedTournamentId);
            if (result.IsSuccess)
                _leaderboard = result.Value.ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConnectToSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/hubs/tournament"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Guid, object>("LeaderboardUpdated", async (tournamentId, leaderboard) =>
        {
            if (tournamentId == _selectedTournamentId)
            {
                await LoadLeaderboardAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.Reconnecting += _ => { _isConnected = false; InvokeAsync(StateHasChanged); return Task.CompletedTask; };
        _hubConnection.Reconnected += _ => { _isConnected = true; InvokeAsync(StateHasChanged); return Task.CompletedTask; };

        try
        {
            await _hubConnection.StartAsync();
            _isConnected = true;
            if (_selectedTournamentId != Guid.Empty)
                await _hubConnection.SendAsync("JoinTournamentGroup", _selectedTournamentId.ToString());
        }
        catch
        {
            _isConnected = false;
        }
    }

    private async Task OnTournamentChanged(object? _)
    {
        if (_hubConnection?.State == HubConnectionState.Connected && _selectedTournamentId != Guid.Empty)
            await _hubConnection.SendAsync("JoinTournamentGroup", _selectedTournamentId.ToString());
        await LoadLeaderboardAsync();
    }

    private async Task RefreshLeaderboard()
    {
        await LoadLeaderboardAsync();
    }

    private string GetRowClass(int rank) => rank switch
    {
        1 => "rank-gold",
        2 => "rank-silver",
        3 => "rank-bronze",
        _ => ""
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
