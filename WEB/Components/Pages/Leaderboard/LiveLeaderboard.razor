</style>

@code {
    [Parameter] public Guid TournamentId { get; set; }

    private bool _loading = false;
    private bool _isConnected = false;
    private int _activeTab = 0;
    private List<LeaderboardEntryDto> _leaderboard = new();
    private List<PlayerLeaderboardEntryDto> _playerLeaderboard = new();
    private List<TournamentListDto> _tournaments = new();
    private Guid _selectedTournamentId;
    private TournamentDto? _tournamentDto;
    private Dictionary<int, double> _placementMultipliers = new();
    private HubConnection? _hubConnection;

    // Overlay
    private bool _showOverlay = false;
    private bool _overlayIsWinner = false;
    private string _overlayTeamName = "";
    private HashSet<Guid> _prevMatchPointIds = new();
    private bool _prevWasCompleted = false;
    private bool _isFirstLoad = true;
    private Queue<(string name, bool isWinner)> _overlayQueue = new();
    private CancellationTokenSource? _overlayDismissCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadTournamentsAsync();
        if (TournamentId != Guid.Empty)
        {
            _selectedTournamentId = TournamentId;
            await LoadLeaderboardAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await ConnectToSignalRAsync();
    }

    private async Task LoadTournamentsAsync()
    {
        var result = await TournamentService.GetTournamentsAsync(new TournamentQueryDto { PageSize = 50 });
        if (result.IsSuccess) _tournaments = result.Value.Items.ToList();
    }

    private async Task LoadLeaderboardAsync()
    {
        if (_selectedTournamentId == Guid.Empty) return;
        _loading = true;
        try
        {
            var teamResult       = await LeaderboardService.GetTournamentLeaderboardAsync(_selectedTournamentId);
            var playerResult     = await LeaderboardService.GetPlayerLeaderboardAsync(_selectedTournamentId);
            var tournamentResult = await TournamentService.GetTournamentByIdAsync(_selectedTournamentId);

            bool hasWinner = tournamentResult.IsSuccess && tournamentResult.Value.WinnerTeamId.HasValue;

            if (teamResult.IsSuccess)
            {
                var newLb = teamResult.Value.ToList();
                var newMp = newLb.Where(e => e.IsMatchPoint).Select(e => e.TeamId).ToHashSet();

                if (!_isFirstLoad && !hasWinner)
                {
                    foreach (var id in newMp.Except(_prevMatchPointIds))
                    {
                        var name = newLb.FirstOrDefault(e => e.TeamId == id)?.TeamName ?? "Equipo";
                        _overlayQueue.Enqueue((name, false));
                    }
                }
                _prevMatchPointIds = newMp;
                _leaderboard = newLb;
            }

            if (playerResult.IsSuccess) _playerLeaderboard = playerResult.Value.ToList();

            if (tournamentResult.IsSuccess)
            {
                _tournamentDto = tournamentResult.Value;

                // Parse placement multipliers for Scoring tab
                try { _placementMultipliers = JsonSerializer.Deserialize<Dictionary<int, double>>(_tournamentDto.PlacementPointsJson) ?? new(); }
                catch { _placementMultipliers = new(); }

                if (!_prevWasCompleted && _tournamentDto.WinnerTeamId.HasValue)
                {
                    var name = _leaderboard.FirstOrDefault(e => e.TeamId == _tournamentDto.WinnerTeamId)?.TeamName ?? "Equipo";
                    _overlayQueue.Enqueue((name, true));
                    _prevWasCompleted = true;
                }
            }

            _isFirstLoad = false;
            await ProcessOverlayQueueAsync();
        }
        finally { _loading = false; }
    }

    private async Task ProcessOverlayQueueAsync()
    {
        if (_showOverlay || !_overlayQueue.Any()) return;
        var (name, isWinner) = _overlayQueue.Dequeue();
        _overlayTeamName = name;
        _overlayIsWinner = isWinner;
        _showOverlay = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            if (isWinner)
            {
                await JS.InvokeVoidAsync("launchWinnerConfetti");
                await JS.InvokeVoidAsync("playWinnerSound");
            }
            else
            {
                await JS.InvokeVoidAsync("launchMatchPointConfetti");
                await JS.InvokeVoidAsync("playMatchPointSound");
            }
        }
        catch { }
        _overlayDismissCts?.Cancel();
        _overlayDismissCts = new CancellationTokenSource();
        var token = _overlayDismissCts.Token;
        _ = Task.Delay(6000, token).ContinueWith(async _ =>
        {
            if (!token.IsCancellationRequested)
                await InvokeAsync(async () => { await DismissOverlay(); });
        }, TaskScheduler.Default);
    }

    private async Task DismissOverlay()
    {
        _overlayDismissCts?.Cancel();
        _showOverlay = false;
        StateHasChanged();
        await Task.Delay(200);
        if (_overlayQueue.Any()) await ProcessOverlayQueueAsync();
    }

    private async Task ConnectToSignalRAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/hubs/tournament"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Guid, object>("LeaderboardUpdated", async (tournamentId, _) =>
        {
            if (tournamentId == _selectedTournamentId)
            {
                await LoadLeaderboardAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<Guid, string>("TournamentStatusChanged", async (tournamentId, status) =>
        {
            if (tournamentId == _selectedTournamentId && status == "Completed")
            {
                await LoadLeaderboardAsync();
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.Reconnecting += _ => { _isConnected = false; InvokeAsync(StateHasChanged); return Task.CompletedTask; };
        _hubConnection.Reconnected  += async _ =>
        {
            _isConnected = true;
            if (_selectedTournamentId != Guid.Empty)
                await _hubConnection.SendAsync("JoinTournamentGroup", _selectedTournamentId.ToString());
            await InvokeAsync(StateHasChanged);
        };

        try
        {
            await _hubConnection.StartAsync();
            _isConnected = true;
            if (_selectedTournamentId != Guid.Empty)
                await _hubConnection.SendAsync("JoinTournamentGroup", _selectedTournamentId.ToString());
        }
        catch { _isConnected = false; }
    }

    private async Task OnTournamentChanged(object? _)
    {
        _prevMatchPointIds.Clear();
        _prevWasCompleted = false;
        _isFirstLoad = true;
        _overlayQueue.Clear();
        _showOverlay = false;
        _placementMultipliers.Clear();
        if (_hubConnection?.State == HubConnectionState.Connected && _selectedTournamentId != Guid.Empty)
            await _hubConnection.SendAsync("JoinTournamentGroup", _selectedTournamentId.ToString());
        await LoadLeaderboardAsync();
    }

    private async Task RefreshLeaderboard() => await LoadLeaderboardAsync();

    private string GetRowClass(int rank) => rank switch
    {
        1 => "rank-gold",
        2 => "rank-silver",
        3 => "rank-bronze",
        _ => ""
    };

    private static string ScoringPlacementIcon(int placement) => placement switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        _ => ""
    };

    public async ValueTask DisposeAsync()
    {
        _overlayDismissCts?.Cancel();
        if (_hubConnection is not null) await _hubConnection.DisposeAsync();
    }
}
