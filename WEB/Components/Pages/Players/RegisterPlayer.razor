@page "/players/register"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using WarzoneTournament.Application.Common.Interfaces
@using WarzoneTournament.Application.DTOs.Player
@using WarzoneTournament.Application.DTOs.Discord
@using WarzoneTournament.Domain.Enums
@inject IPlayerService PlayerService
@inject IDiscordNotificationService DiscordService
@inject NavigationManager NavManager

<PageTitle>Registrar Jugador - Warzone</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">Registrar Jugador</h1>
        <RadzenButton Text="Volver" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => NavManager.NavigateTo("/players"))" />
    </div>

    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" class="mb-4">
        <strong>¿Cómo funciona el registro?</strong><br />
        Cada jugador necesita un nombre de usuario único. El Discord ID vincula al jugador con el bot de Discord
        para auto-registrar evidencias. El Activision ID es su nombre en el juego (ej: <code>NombreJugador#1234567</code>).
    </RadzenAlert>

    <RadzenCard style="max-width:600px">
        <RadzenTemplateForm TItem="CreatePlayerDto" Data="@_model" Submit="@OnSubmit">
            <div style="display:flex;flex-direction:column;gap:20px">

                <div>
                    <RadzenLabel Text="Nombre de Usuario *" />
                    <RadzenTextBox @bind-Value="_model.Username"
                                   Placeholder="ej: SniperElite99"
                                   Style="width:100%"
                                   @oninput="@ClearError" />
                    <small style="color:var(--rz-text-secondary-color)">
                        Solo letras, números, guiones y # (sin espacios). Máx 100 caracteres.
                    </small>
                </div>

                <div>
                    <RadzenLabel Text="Activision ID (nombre en juego)" />
                    <RadzenTextBox @bind-Value="_model.ActivisionId"
                                   Placeholder="ej: SniperElite99#1234567"
                                   Style="width:100%" />
                    <small style="color:var(--rz-text-secondary-color)">
                        Visible en el perfil de CoD. Necesario para verificación de resultados.
                    </small>
                </div>

                <div>
                    <RadzenLabel Text="Discord ID" />
                    <div style="display:flex;gap:8px;margin-top:2px;align-items:center">
                        <RadzenTextBox @bind-Value="_model.DiscordId"
                                       Placeholder="ej: 123456789012345678"
                                       Style="flex:1"
                                       @oninput="OnDiscordIdChanged" />
                        <RadzenButton Text="@(_fetchingDiscord ? "Buscando..." : "Buscar en Discord")"
                                      Icon="@(_fetchingDiscord ? "" : "person_search")"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Small"
                                      Click="@FetchDiscordUserAsync"
                                      Disabled="@(_fetchingDiscord || string.IsNullOrWhiteSpace(_model.DiscordId))" />
                    </div>
                    <small style="color:var(--rz-text-secondary-color)">
                        ID numérico de Discord (17-20 dígitos). En Discord: <code>Ajustes → Mi Cuenta → Copiar ID de usuario</code>.
                        Necesario para vinculación con el bot.
                    </small>

                    @if (_discordUser is not null)
                    {
                        <div style="display:flex;align-items:center;gap:12px;margin-top:10px;
                                    background:var(--rz-base-200,rgba(88,101,242,0.08));
                                    border:1px solid rgba(88,101,242,0.3);
                                    border-radius:8px;padding:10px 14px">
                            @if (!string.IsNullOrEmpty(_discordUser.AvatarUrl))
                            {
                                <img src="@_discordUser.AvatarUrl" alt="avatar"
                                     style="width:48px;height:48px;border-radius:50%;flex-shrink:0;object-fit:cover" />
                            }
                            else
                            {
                                <div style="width:48px;height:48px;border-radius:50%;background:#5865f2;display:flex;align-items:center;justify-content:center;font-size:1.4em;flex-shrink:0">
                                    @_discordUser.Username[0].ToString().ToUpper()
                                </div>
                            }
                            <div>
                                <div style="font-weight:700;font-size:1em">@_discordUser.Username</div>
                                @if (!string.IsNullOrEmpty(_discordUser.GlobalName) && _discordUser.GlobalName != _discordUser.Username)
                                {
                                    <div style="font-size:0.85em;color:var(--rz-text-secondary-color)">@_discordUser.GlobalName</div>
                                }
                                <div style="font-size:0.75em;color:#57f287;margin-top:2px">✓ Encontrado en Discord</div>
                            </div>
                        </div>
                    }
                    @if (_discordFetchError is not null)
                    {
                        <small style="color:var(--rz-danger);display:block;margin-top:4px">⚠ @_discordFetchError</small>
                    }
                </div>

                <div>
                    <RadzenLabel Text="Username de Discord" />
                    <RadzenTextBox @bind-Value="_model.DiscordUsername"
                                   Placeholder="ej: sniperplayer (se auto-rellena al buscar)"
                                   Style="width:100%" />
                </div>

                <div>
                    <RadzenLabel Text="Plataforma *" />
                    <RadzenDropDown @bind-Value="_model.Platform"
                                   Data="@(Enum.GetValues<Platform>())"
                                   Style="width:100%" />
                </div>

                <div>
                    <RadzenLabel Text="Email (opcional)" />
                    <RadzenTextBox @bind-Value="_model.Email"
                                   Placeholder="jugador@ejemplo.com"
                                   Style="width:100%" />
                </div>

                <div>
                    <RadzenLabel Text="País (opcional)" />
                    <RadzenTextBox @bind-Value="_model.Country"
                                   Placeholder="ej: Colombia"
                                   Style="width:100%" />
                </div>

                <div>
                    <RadzenLabel Text="URL de Avatar (opcional)" />
                    <RadzenTextBox @bind-Value="_model.AvatarUrl"
                                   Placeholder="https://..."
                                   Style="width:100%" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat">
                        @_errorMessage
                    </RadzenAlert>
                }

                @if (!string.IsNullOrEmpty(_successMessage))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat">
                        @_successMessage
                        <br /><strong>Jugador registrado con ID: @_createdId</strong>
                    </RadzenAlert>
                }

                <div style="display:flex;gap:12px;padding-top:8px">
                    <RadzenButton ButtonType="ButtonType.Submit"
                                  Text="Registrar Jugador"
                                  Icon="person_add"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Disabled="@_saving" />
                    <RadzenButton Text="Registrar otro"
                                  Icon="refresh"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@ResetForm"
                                  Disabled="@(!_registeredAtLeastOne)" />
                    <RadzenButton Text="Ver todos los jugadores"
                                  Icon="list"
                                  ButtonStyle="ButtonStyle.Light"
                                  Click="@(() => NavManager.NavigateTo("/players"))" />
                </div>
            </div>
        </RadzenTemplateForm>
    </RadzenCard>
</div>

@code {
    private CreatePlayerDto _model = new();
    private bool _saving = false;
    private string? _errorMessage;
    private string? _successMessage;
    private string? _createdId;
    private bool _registeredAtLeastOne = false;

    private bool _fetchingDiscord = false;
    private DiscordUserDto? _discordUser;
    private string? _discordFetchError;

    private void ClearError(ChangeEventArgs _) => _errorMessage = null;

    private void OnDiscordIdChanged(ChangeEventArgs _)
    {
        _discordUser = null;
        _discordFetchError = null;
        _errorMessage = null;
    }

    private async Task FetchDiscordUserAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.DiscordId)) return;
        _fetchingDiscord = true; _discordFetchError = null; _discordUser = null;

        var result = await DiscordService.GetDiscordUserAsync(_model.DiscordId.Trim());
        if (result.IsSuccess)
        {
            _discordUser = result.Value;
            // Auto-rellena username de Discord
            _model.DiscordUsername = _discordUser.Username;
            // Auto-rellena avatar si aún no se llenó
            if (string.IsNullOrEmpty(_model.AvatarUrl))
                _model.AvatarUrl = _discordUser.AvatarUrl;
            // Sugiere nombre de usuario del juego si está vacío
            if (string.IsNullOrEmpty(_model.Username))
                _model.Username = _discordUser.DisplayName;
        }
        else
        {
            _discordFetchError = result.Error;
        }

        _fetchingDiscord = false;
    }

    private async Task OnSubmit()
    {
        _saving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var result = await PlayerService.CreatePlayerAsync(_model);
            if (result.IsSuccess)
            {
                _successMessage = $"¡Jugador '{result.Value.Username}' registrado exitosamente!";
                _createdId = result.Value.Id.ToString()[..8] + "...";
                _registeredAtLeastOne = true;
            }
            else
            {
                _errorMessage = result.Error;
            }
        }
        finally { _saving = false; }
    }

    private void ResetForm()
    {
        _model = new();
        _errorMessage = null;
        _successMessage = null;
        _createdId = null;
        _discordUser = null;
        _discordFetchError = null;
    }
}
