@inherits LayoutComponentBase
@using Radzen

<RadzenLayout>
    <RadzenHeader>
        <div class="header-content">
            <RadzenSidebarToggle Click="@ToggleSidebar" />
            <span class="app-title">
                <span class="title-icon">⚡</span>
                WARZONE TOURNAMENT
            </span>
            <div class="header-right">
                <RadzenBadge Text="LIVE" BadgeStyle="BadgeStyle.Danger" class="live-badge" />
            </div>
        </div>
    </RadzenHeader>
    <RadzenSidebar @ref="_sidebar" @bind-Expanded="@_sidebarExpanded">
        <NavMenu />
    </RadzenSidebar>
    <RadzenBody>
        <RadzenContentContainer Name="main">
            @Body
        </RadzenContentContainer>
    </RadzenBody>
</RadzenLayout>

<RadzenComponents />

@code {
    private RadzenSidebar _sidebar = null!;
    private bool _sidebarExpanded = true;

    void ToggleSidebar() => _sidebarExpanded = !_sidebarExpanded;
}
